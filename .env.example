# DK-HQ Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to version control

# ============================================
# AI/LLM SERVICES
# ============================================

# OpenAI - https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Anthropic Claude - https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ============================================
# UK GOVERNMENT APIs
# ============================================

# Companies House - https://developer.company-information.service.gov.uk/
COMPANIES_HOUSE_API_KEY=

# HMRC - https://developer.service.hmrc.gov.uk/
HMRC_CLIENT_ID=
HMRC_CLIENT_SECRET=

# ============================================
# ACCOUNTING SOFTWARE
# ============================================

# Xero - https://developer.xero.com/app/manage
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XERO_REDIRECT_URI=http://localhost:3000/api/auth/callback/xero

# QuickBooks - https://developer.intuit.com/app/developer/dashboard
QB_CLIENT_ID=
QB_CLIENT_SECRET=
QB_REDIRECT_URI=http://localhost:3000/api/auth/callback/quickbooks

# Sage - https://developer.sage.com/api/accounts/
SAGE_CLIENT_ID=
SAGE_CLIENT_SECRET=
SAGE_REDIRECT_URI=http://localhost:3000/api/auth/callback/sage

# ============================================
# DATABASE
# ============================================

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/dk_hq

# MongoDB connection string (if using)
MONGODB_URI=mongodb://localhost:27017/dk_hq

# ============================================
# AUTHENTICATION
# ============================================

# NextAuth / Auth secret
AUTH_SECRET=your-super-secret-key-here
NEXTAUTH_URL=http://localhost:3000

# ============================================
# STORAGE
# ============================================

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-2
AWS_S3_BUCKET=dk-hq-documents

# ============================================
# EMAIL
# ============================================

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@indusnexus.com

# ============================================
# APPLICATION
# ============================================

NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000
